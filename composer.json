{
	"name": "adamsilverstein/client-side-media-experiments",
	"description": "WordPress plugin enabling client-side media processing on Firefox and Safari via COEP/COOP headers.",
	"type": "wordpress-plugin",
	"license": "GPL-2.0-or-later",
	"require": {
		"php": ">=7.4"
	},
	"require-dev": {
		"wp-coding-standards/wpcs": "^3.0",
		"phpcompatibility/phpcompatibility-wp": "^2.1",
		"dealerdirect/phpcodesniffer-composer-installer": "^1.0",
		"phpunit/phpunit": "^9.6 || ^10.5",
		"wp-phpunit/wp-phpunit": "^6.8",
		"yoast/phpunit-polyfills": "^2.0 || ^3.0"
	},
	"scripts": {
		"lint": "phpcs",
		"lint:fix": "phpcbf",
		"test": "phpunit"
	},
	"config": {
		"allow-plugins": {
			"dealerdirect/phpcodesniffer-composer-installer": true
		}
	}
}
